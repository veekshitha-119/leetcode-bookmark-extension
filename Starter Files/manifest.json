{
  "manifest_version": 3,
  "name": "Problem Tracker",
  "version": "0.1",
  "author": "First Last",
  "description": "Chrome Extension that helps us to track problems",
  "permissions": [
    "storage",  
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources" : [
    {
      "resources": [
        "assets/bookmark.png",
        "assets/delete.png",
        "assets/play.png"
      ],
      "matches" : ["<all_urls>"]
    }
  ],
  "action": {
    "default_icon": {
      "16": "assets/ext-icon.png",
      "24": "assets/ext-icon.png",
      "32": "assets/ext-icon.png"
    },
    "default_popup": "pop_up.html",
    "default_title": "Problem Tracker"
  }
}
